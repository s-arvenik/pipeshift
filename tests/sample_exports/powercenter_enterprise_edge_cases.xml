        <INSTANCE NAME="TGT_ACCOUNT_BRIDGE" TYPE="TARGET" TRANSFORMATION_NAME="TGT_ACCOUNT_BRIDGE"/>
      </MAPPING>

      <MAPPING NAME="m_MARKETING_EVENTS_FLATFILE_REJECTS" DESCRIPTION="Flat file ingestion with reject target and bad-row routing" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="SQ_FF_MARKETING_EVENTS" TYPE="Source Qualifier" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Source Type" VALUE="File"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="exp_VALIDATE_EVENT" TYPE="Expression" REUSABLE="NO">
          <TRANSFORMFIELD NAME="EVENT_ID" DATATYPE="string" PRECISION="40" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="REJECT_REASON" DATATYPE="string" PRECISION="200" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION="IIF(ISNULL(EVENT_ID),'Missing event id',IIF(ISNULL(ACCOUNT_ID),'Missing account id',NULL))"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="rtr_EVENT_VALIDITY" TYPE="Router" REUSABLE="NO">
          <GROUP NAME="VALID_EVENT" EXPRESSION="ISNULL(REJECT_REASON)"/>
          <GROUP NAME="REJECT_EVENT" EXPRESSION="NOT ISNULL(REJECT_REASON)"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="exp_EVENT_DEFAULTS" TYPE="Expression" REUSABLE="NO">
          <TRANSFORMFIELD NAME="EVENT_NAME_OUT" DATATYPE="string" PRECISION="80" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION="IIF(ISNULL(EVENT_NAME),'unknown',LOWER(EVENT_NAME))"/>
        </TRANSFORMATION>
        <INSTANCE NAME="FF_MARKETING_EVENTS" TYPE="SOURCE" TRANSFORMATION_NAME="FF_MARKETING_EVENTS"/>
        <INSTANCE NAME="TGT_MARKETING_EVENT" TYPE="TARGET" TRANSFORMATION_NAME="TGT_MARKETING_EVENT"/>
        <INSTANCE NAME="FF_REJECT_EVENTS" TYPE="TARGET" TRANSFORMATION_NAME="FF_REJECT_EVENTS"/>
      </MAPPING>

      <MAPPING NAME="m_POLICY_XML_NORMALIZER" DESCRIPTION="XML source parsing, mapplet, and normalizer" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="SQ_XML_POLICY_FEED" TYPE="Source Qualifier" REUSABLE="NO"/>
        <INSTANCE NAME="mplt_PARSE_POLICY_XML" TYPE="MAPPLET" TRANSFORMATION_NAME="mplt_PARSE_POLICY_XML"/>
        <TRANSFORMATION NAME="fil_POSITIVE_LIMIT" TYPE="Filter" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Filter Condition" VALUE="COVERAGE_LIMIT &gt; 0"/>
        </TRANSFORMATION>
        <INSTANCE NAME="XML_POLICY_FEED" TYPE="SOURCE" TRANSFORMATION_NAME="XML_POLICY_FEED"/>
        <INSTANCE NAME="TGT_POLICY_COVERAGE" TYPE="TARGET" TRANSFORMATION_NAME="TGT_POLICY_COVERAGE"/>
      </MAPPING>

      <MAPPING NAME="m_UNCONNECTED_LOOKUP_EXPRESSION" DESCRIPTION="Expression calls unconnected lookup" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="SQ_SRC_ACCOUNT_MIN" TYPE="Source Qualifier" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT ACCOUNT_ID, COUNTRY_CODE FROM SRC_ACCOUNT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="lkp_COUNTRY_UNCONNECTED" TYPE="Lookup Procedure" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Lookup condition" VALUE="COUNTRY_CODE = :LKP.LKP_COUNTRY_UNCONNECTED(IN_COUNTRY_CODE)"/>
          <TABLEATTRIBUTE NAME="Lookup type" VALUE="Unconnected"/>
          <TRANSFORMFIELD NAME="IN_COUNTRY_CODE" DATATYPE="string" PRECISION="3" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="RETURN_VALUE" DATATYPE="string" PRECISION="80" SCALE="0" PORTTYPE="RETURN"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="exp_CALL_UNCONNECTED" TYPE="Expression" REUSABLE="NO">
          <TRANSFORMFIELD NAME="COUNTRY_CODE" DATATYPE="string" PRECISION="3" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="COUNTRY_NAME" DATATYPE="string" PRECISION="80" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION=":LKP.LKP_COUNTRY_UNCONNECTED(COUNTRY_CODE)"/>
        </TRANSFORMATION>
        <INSTANCE NAME="TGT_ACCOUNT_BRIDGE" TYPE="TARGET" TRANSFORMATION_NAME="TGT_ACCOUNT_BRIDGE"/>
      </MAPPING>

      <MAPPING NAME="m_STORED_PROC_SQL_JAVA_EDGE" DESCRIPTION="SQL transformation, Java transformation, stored procedure and custom SQL" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="SQ_RECON_BASE" TYPE="Source Qualifier" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT '$$BATCH_ID' BATCH_ID, COUNT(*) SRC_CNT FROM SRC_TXN"/>
          <TABLEATTRIBUTE NAME="Pre SQL" VALUE="ALTER SESSION SET QUERY_TAG='pc_fixture'"/>
          <TABLEATTRIBUTE NAME="Post SQL" VALUE="CALL LOG_EXTRACT_COMPLETE('SRC_TXN')"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="sql_TARGET_COUNT" TYPE="SQL Transformation" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="SQL Query" VALUE="SELECT COUNT(*) AS TGT_CNT FROM TGT_TXN_FACT WHERE TXN_DATE = TO_DATE(?,'YYYY-MM-DD')"/>
          <TABLEATTRIBUTE NAME="SQL ports" VALUE="RUN_DATE,TGT_CNT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="java_BUILD_RECON_JSON" TYPE="Java Transformation" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Java Code" VALUE="String status = SRC_CNT == TGT_CNT ? &quot;MATCH&quot; : &quot;MISMATCH&quot;; RECON_JSON = &quot;{\\&quot;status\\&quot;:\\&quot;&quot; + status + &quot;\\&quot;}&quot;;"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="sp_PERSIST_RECON" TYPE="Stored Procedure" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Stored Procedure Name" VALUE="PKG_RECON.PERSIST_RESULT"/>
          <TABLEATTRIBUTE NAME="Call Text" VALUE="PKG_RECON.PERSIST_RESULT(:BATCH_ID,:RECON_JSON)"/>
        </TRANSFORMATION>
      </MAPPING>

      <MAPPING NAME="m_TARGET_LOAD_ORDER_AND_CONSTRAINTS" DESCRIPTION="Multiple target load order and target update override" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="SQ_ACCOUNT_TARGET_ORDER" TYPE="Source Qualifier" REUSABLE="NO"/>
        <TRANSFORMATION NAME="exp_SPLIT_TARGETS" TYPE="Expression" REUSABLE="NO">
          <TRANSFORMFIELD NAME="ACCOUNT_ID" DATATYPE="decimal" PRECISION="10" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="IS_PARENT" DATATYPE="string" PRECISION="1" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION="IIF(ISNULL(PARENT_ACCOUNT_ID),'Y','N')"/>
        </TRANSFORMATION>
        <TARGETLOADORDER ORDER="1" TARGETINSTANCE="TGT_ACCOUNT_DIM_SCD2"/>
        <TARGETLOADORDER ORDER="2" TARGETINSTANCE="TGT_ACCOUNT_BRIDGE"/>
        <INSTANCE NAME="TGT_ACCOUNT_DIM_SCD2" TYPE="TARGET" TRANSFORMATION_NAME="TGT_ACCOUNT_DIM_SCD2">
          <TABLEATTRIBUTE NAME="Target Update Override" VALUE="UPDATE TGT_ACCOUNT_DIM_SCD2 SET IS_CURRENT='N', EFFECTIVE_TO=SYSDATE-1 WHERE ACCOUNT_ID=:TU.ACCOUNT_ID AND IS_CURRENT='Y'"/>
        </INSTANCE>
        <INSTANCE NAME="TGT_ACCOUNT_BRIDGE" TYPE="TARGET" TRANSFORMATION_NAME="TGT_ACCOUNT_BRIDGE"/>
      </MAPPING>

      <WORKLET NAME="wl_LOAD_CORE_DIMS" DESCRIPTION="Reusable worklet for core dimensions">
        <TASK NAME="Start" TYPE="Start"/>
        <SESSION NAME="s_ACCOUNT_DIM_SCD2_FULL" MAPPINGNAME="m_ACCOUNT_DIM_SCD2_FULL" REUSABLE="NO" CONFIG_NAME="cfg_HIGH_VOLUME">
          <ATTRIBUTE NAME="Parameter File Name" VALUE="$PMRootDir/param/enterprise_fixture.parm"/>
          <ATTRIBUTE NAME="Session retry on deadlock" VALUE="YES"/>
          <ATTRIBUTE NAME="Pre-session command" VALUE="sh $PMRootDir/Scripts/pre_account_dim.sh"/>
          <ATTRIBUTE NAME="Post-session success command" VALUE="sh $PMRootDir/Scripts/post_account_dim.sh"/>
          <SESSTRANSFORMATIONINST TRANSFORMATIONNAME="SQ_SRC_ACCOUNT" TRANSFORMATIONTYPE="Source Qualifier" INSTANCE_NAME="SQ_SRC_ACCOUNT">
            <ATTRIBUTE NAME="Source Connection Value" VALUE="cn_ORACLE_SRC"/>
          </SESSTRANSFORMATIONINST>
          <SESSTRANSFORMATIONINST TRANSFORMATIONNAME="TGT_ACCOUNT_DIM_SCD2" TRANSFORMATIONTYPE="Target Definition" INSTANCE_NAME="TGT_ACCOUNT_DIM_SCD2">
            <ATTRIBUTE NAME="Target Connection Value" VALUE="cn_SNOWFLAKE_TGT"/>
            <ATTRIBUTE NAME="Truncate target table option" VALUE="NO"/>
          </SESSTRANSFORMATIONINST>
          <PARTITION DESCRIPTION="Hash partition by account" NAME="Partition #1"/>
          <PARTITION DESCRIPTION="Hash partition by account" NAME="Partition #2"/>
        </SESSION>
        <SESSION NAME="s_HIERARCHY_BRIDGE_SELF_JOIN" MAPPINGNAME="m_HIERARCHY_BRIDGE_SELF_JOIN" REUSABLE="NO"/>
        <WORKFLOWLINK FROMTASK="Start" TOTASK="s_ACCOUNT_DIM_SCD2_FULL" CONDITION=""/>
        <WORKFLOWLINK FROMTASK="s_ACCOUNT_DIM_SCD2_FULL" TOTASK="s_HIERARCHY_BRIDGE_SELF_JOIN" CONDITION="$s_ACCOUNT_DIM_SCD2_FULL.Status = SUCCEEDED"/>
      </WORKLET>

      <WORKFLOW NAME="wf_ENTERPRISE_DAILY_LOAD" DESCRIPTION="Workflow with worklet, events, decision, command, email, timers and sessions" SERVERNAME="IS_LOCAL" SCHEDULERNAME="Daily">
        <TASK NAME="Start" TYPE="Start"/>
        <TASK NAME="evt_WAIT_FOR_FILES" TYPE="Event Wait">
          <ATTRIBUTE NAME="Event Name" VALUE="MARKETING_FILE_READY"/>
        </TASK>
        <TASK NAME="tmr_DELAY_FOR_SOURCE" TYPE="Timer">
          <ATTRIBUTE NAME="Start Time" VALUE="00:30"/>
        </TASK>
        <WORKLETINST NAME="wl_LOAD_CORE_DIMS" WORKLETNAME="wl_LOAD_CORE_DIMS"/>
        <SESSION NAME="s_TXN_FACT_MULTI_SOURCE" MAPPINGNAME="m_TXN_FACT_MULTI_SOURCE" REUSABLE="NO" CONFIG_NAME="cfg_HIGH_VOLUME">
          <ATTRIBUTE NAME="Treat Source Rows As" VALUE="Data Driven"/>
          <ATTRIBUTE NAME="Commit Interval" VALUE="50000"/>
        </SESSION>
        <SESSION NAME="s_MARKETING_EVENTS_FLATFILE_REJECTS" MAPPINGNAME="m_MARKETING_EVENTS_FLATFILE_REJECTS" REUSABLE="NO">
          <ATTRIBUTE NAME="Source file directory" VALUE="$PMSourceFileDir"/>
          <ATTRIBUTE NAME="Source filename" VALUE="marketing_events_$$RUN_DATE.dat"/>
          <ATTRIBUTE NAME="Reject file directory" VALUE="$PMBadFileDir"/>
        </SESSION>
        <SESSION NAME="s_POLICY_XML_NORMALIZER" MAPPINGNAME="m_POLICY_XML_NORMALIZER" REUSABLE="NO"/>
        <SESSION NAME="s_UNCONNECTED_LOOKUP_EXPRESSION" MAPPINGNAME="m_UNCONNECTED_LOOKUP_EXPRESSION" REUSABLE="NO"/>
        <SESSION NAME="s_STORED_PROC_SQL_JAVA_EDGE" MAPPINGNAME="m_STORED_PROC_SQL_JAVA_EDGE" REUSABLE="NO"/>
        <SESSION NAME="s_TARGET_LOAD_ORDER_AND_CONSTRAINTS" MAPPINGNAME="m_TARGET_LOAD_ORDER_AND_CONSTRAINTS" REUSABLE="NO"/>
        <TASK NAME="dec_RECON_OK" TYPE="Decision">
          <ATTRIBUTE NAME="Decision Condition" VALUE="$s_STORED_PROC_SQL_JAVA_EDGE.Status = SUCCEEDED"/>
        </TASK>
        <TASK NAME="evt_RAISE_LOAD_DONE" TYPE="Event Raise">
          <ATTRIBUTE NAME="Event Name" VALUE="WAREHOUSE_LOAD_DONE"/>
        </TASK>
        <TASK NAME="cmd_ARCHIVE_FILES" TYPE="Command">
          <ATTRIBUTE NAME="Command" VALUE="sh $PMRootDir/Scripts/archive_files.sh $$RUN_DATE"/>
        </TASK>
        <TASK NAME="email_FAILURE_NOTICE" TYPE="Email">
          <ATTRIBUTE NAME="Email User Name" VALUE="data-ops@example.invalid"/>
          <ATTRIBUTE NAME="Email Subject" VALUE="PowerCenter fixture workflow failed"/>
        </TASK>
        <WORKFLOWLINK FROMTASK="Start" TOTASK="evt_WAIT_FOR_FILES" CONDITION=""/>
        <WORKFLOWLINK FROMTASK="evt_WAIT_FOR_FILES" TOTASK="tmr_DELAY_FOR_SOURCE" CONDITION="$evt_WAIT_FOR_FILES.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="tmr_DELAY_FOR_SOURCE" TOTASK="wl_LOAD_CORE_DIMS" CONDITION="$tmr_DELAY_FOR_SOURCE.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="wl_LOAD_CORE_DIMS" TOTASK="s_TXN_FACT_MULTI_SOURCE" CONDITION="$wl_LOAD_CORE_DIMS.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_TXN_FACT_MULTI_SOURCE" TOTASK="s_MARKETING_EVENTS_FLATFILE_REJECTS" CONDITION="$s_TXN_FACT_MULTI_SOURCE.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_MARKETING_EVENTS_FLATFILE_REJECTS" TOTASK="s_POLICY_XML_NORMALIZER" CONDITION="$s_MARKETING_EVENTS_FLATFILE_REJECTS.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_POLICY_XML_NORMALIZER" TOTASK="s_UNCONNECTED_LOOKUP_EXPRESSION" CONDITION="$s_POLICY_XML_NORMALIZER.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_UNCONNECTED_LOOKUP_EXPRESSION" TOTASK="s_STORED_PROC_SQL_JAVA_EDGE" CONDITION="$s_UNCONNECTED_LOOKUP_EXPRESSION.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_STORED_PROC_SQL_JAVA_EDGE" TOTASK="s_TARGET_LOAD_ORDER_AND_CONSTRAINTS" CONDITION="$s_STORED_PROC_SQL_JAVA_EDGE.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_TARGET_LOAD_ORDER_AND_CONSTRAINTS" TOTASK="dec_RECON_OK" CONDITION="$s_TARGET_LOAD_ORDER_AND_CONSTRAINTS.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="dec_RECON_OK" TOTASK="evt_RAISE_LOAD_DONE" CONDITION="$dec_RECON_OK.Condition = TRUE"/>
        <WORKFLOWLINK FROMTASK="evt_RAISE_LOAD_DONE" TOTASK="cmd_ARCHIVE_FILES" CONDITION="$evt_RAISE_LOAD_DONE.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_STORED_PROC_SQL_JAVA_EDGE" TOTASK="email_FAILURE_NOTICE" CONDITION="$s_STORED_PROC_SQL_JAVA_EDGE.Status = FAILED"/>
      </WORKFLOW>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
