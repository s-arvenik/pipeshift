        <CONNECTOR FROMINSTANCE="jnr_ACCOUNT_STATUS" FROMINSTANCETYPE="Joiner" FROMFIELD="ACCOUNT_ID" TOINSTANCE="lkp_ACCOUNT_DIM_DYNAMIC" TOINSTANCETYPE="Lookup Procedure" TOFIELD="IN_ACCOUNT_ID"/>
