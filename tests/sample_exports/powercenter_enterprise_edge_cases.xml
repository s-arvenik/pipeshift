          <TRANSFORMFIELD NAME="HIERARCHY_LEVEL" DATATYPE="decimal" PRECISION="4" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION="IIF(ISNULL(PARENT_ACCOUNT_ID),0,1)"/>
