          <TRANSFORMFIELD NAME="STATUS_CODE" DATATYPE="string" PRECISION="20" SCALE="0" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="UPDATED_AT" DATATYPE="date/time" PRECISION="19" SCALE="0" PORTTYPE="OUTPUT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="exp_CLEAN_CUSTOMER" TYPE="Expression" REUSABLE="NO">
          <TRANSFORMFIELD NAME="CUSTOMER_NAME" DATATYPE="string" PRECISION="100" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="EMAIL_ADDRESS" DATATYPE="string" PRECISION="150" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="CUSTOMER_NAME_CLEAN" DATATYPE="string" PRECISION="100" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION="INITCAP(LTRIM(RTRIM(CUSTOMER_NAME)))"/>
          <TRANSFORMFIELD NAME="EMAIL_CLEAN" DATATYPE="string" PRECISION="150" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION="LOWER(LTRIM(RTRIM(EMAIL_ADDRESS)))"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="exp_DERIVE_EMAIL_DOMAIN" TYPE="Expression" REUSABLE="NO">
          <TRANSFORMFIELD NAME="EMAIL_CLEAN" DATATYPE="string" PRECISION="150" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="EMAIL_DOMAIN" DATATYPE="string" PRECISION="100" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION="IIF(INSTR(EMAIL_CLEAN,'@') &gt; 0, SUBSTR(EMAIL_CLEAN, INSTR(EMAIL_CLEAN,'@') + 1), 'unknown')"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="lkp_STATUS_DESC" TYPE="Lookup Procedure" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Lookup Sql Override" VALUE="SELECT STATUS_CODE, STATUS_DESC, STATUS_GROUP FROM SRC_STATUS_REF WHERE STATUS_GROUP IN ('CUSTOMER','COMMON')"/>
          <TRANSFORMFIELD NAME="STATUS_CODE" DATATYPE="string" PRECISION="20" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="STATUS_DESC" DATATYPE="string" PRECISION="80" SCALE="0" PORTTYPE="LOOKUP/OUTPUT"/>
          <TRANSFORMFIELD NAME="STATUS_GROUP" DATATYPE="string" PRECISION="40" SCALE="0" PORTTYPE="LOOKUP/OUTPUT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="lkp_EXISTING_CUSTOMER" TYPE="Lookup Procedure" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Lookup condition" VALUE="CUSTOMER_ID = IN_CUSTOMER_ID"/>
          <TRANSFORMFIELD NAME="IN_CUSTOMER_ID" DATATYPE="decimal" PRECISION="10" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="CUSTOMER_KEY" DATATYPE="decimal" PRECISION="10" SCALE="0" PORTTYPE="LOOKUP/OUTPUT"/>
          <TRANSFORMFIELD NAME="CURRENT_HASH" DATATYPE="string" PRECISION="64" SCALE="0" PORTTYPE="LOOKUP/OUTPUT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="exp_HASH_CUSTOMER" TYPE="Expression" REUSABLE="NO">
          <TRANSFORMFIELD NAME="CUSTOMER_NAME_CLEAN" DATATYPE="string" PRECISION="100" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="EMAIL_DOMAIN" DATATYPE="string" PRECISION="100" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="STATUS_DESC" DATATYPE="string" PRECISION="80" SCALE="0" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="ROW_HASH" DATATYPE="string" PRECISION="64" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION="MD5(CUSTOMER_NAME_CLEAN || '|' || EMAIL_DOMAIN || '|' || STATUS_DESC)"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="rtr_CUSTOMER_CHANGE" TYPE="Router" REUSABLE="NO">
          <GROUP NAME="INSERT_ROWS" DESCRIPTION="New customers" EXPRESSION="ISNULL(CUSTOMER_KEY)"/>
          <GROUP NAME="UPDATE_ROWS" DESCRIPTION="Changed customers" EXPRESSION="NOT ISNULL(CUSTOMER_KEY) AND ROW_HASH != CURRENT_HASH"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="seq_CUSTOMER_KEY" TYPE="Sequence" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Start Value" VALUE="100000"/>
          <TRANSFORMFIELD NAME="NEXTVAL" DATATYPE="decimal" PRECISION="10" SCALE="0" PORTTYPE="OUTPUT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="upd_CUSTOMER_DIM" TYPE="Update Strategy" REUSABLE="NO">
          <TRANSFORMFIELD NAME="DD_INSERT_UPDATE" DATATYPE="integer" PRECISION="10" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION="IIF(ISNULL(CUSTOMER_KEY), DD_INSERT, DD_UPDATE)"/>
        </TRANSFORMATION>
        <INSTANCE NAME="SRC_CUSTOMER_RAW" TYPE="SOURCE" TRANSFORMATION_NAME="SRC_CUSTOMER_RAW"/>
        <INSTANCE NAME="TGT_CUSTOMER_DIM" TYPE="TARGET" TRANSFORMATION_NAME="TGT_CUSTOMER_DIM"/>
        <CONNECTOR FROMINSTANCE="SQ_SRC_CUSTOMER_RAW" FROMINSTANCETYPE="Source Qualifier" FROMFIELD="CUSTOMER_NAME" TOINSTANCE="exp_CLEAN_CUSTOMER" TOINSTANCETYPE="Expression" TOFIELD="CUSTOMER_NAME"/>
        <CONNECTOR FROMINSTANCE="exp_CLEAN_CUSTOMER" FROMINSTANCETYPE="Expression" FROMFIELD="EMAIL_CLEAN" TOINSTANCE="exp_DERIVE_EMAIL_DOMAIN" TOINSTANCETYPE="Expression" TOFIELD="EMAIL_CLEAN"/>
        <CONNECTOR FROMINSTANCE="SQ_SRC_CUSTOMER_RAW" FROMINSTANCETYPE="Source Qualifier" FROMFIELD="STATUS_CODE" TOINSTANCE="lkp_STATUS_DESC" TOINSTANCETYPE="Lookup Procedure" TOFIELD="STATUS_CODE"/>
        <CONNECTOR FROMINSTANCE="SQ_SRC_CUSTOMER_RAW" FROMINSTANCETYPE="Source Qualifier" FROMFIELD="CUSTOMER_ID" TOINSTANCE="lkp_EXISTING_CUSTOMER" TOINSTANCETYPE="Lookup Procedure" TOFIELD="IN_CUSTOMER_ID"/>
        <CONNECTOR FROMINSTANCE="exp_CLEAN_CUSTOMER" FROMINSTANCETYPE="Expression" FROMFIELD="CUSTOMER_NAME_CLEAN" TOINSTANCE="exp_HASH_CUSTOMER" TOINSTANCETYPE="Expression" TOFIELD="CUSTOMER_NAME_CLEAN"/>
        <CONNECTOR FROMINSTANCE="exp_DERIVE_EMAIL_DOMAIN" FROMINSTANCETYPE="Expression" FROMFIELD="EMAIL_DOMAIN" TOINSTANCE="exp_HASH_CUSTOMER" TOINSTANCETYPE="Expression" TOFIELD="EMAIL_DOMAIN"/>
        <CONNECTOR FROMINSTANCE="lkp_STATUS_DESC" FROMINSTANCETYPE="Lookup Procedure" FROMFIELD="STATUS_DESC" TOINSTANCE="exp_HASH_CUSTOMER" TOINSTANCETYPE="Expression" TOFIELD="STATUS_DESC"/>
        <CONNECTOR FROMINSTANCE="exp_HASH_CUSTOMER" FROMINSTANCETYPE="Expression" FROMFIELD="ROW_HASH" TOINSTANCE="rtr_CUSTOMER_CHANGE" TOINSTANCETYPE="Router" TOFIELD="ROW_HASH"/>
        <CONNECTOR FROMINSTANCE="rtr_CUSTOMER_CHANGE" FROMINSTANCETYPE="Router" FROMFIELD="ROW_HASH" TOINSTANCE="upd_CUSTOMER_DIM" TOINSTANCETYPE="Update Strategy" TOFIELD="ROW_HASH"/>
      </MAPPING>

      <MAPPING NAME="m_LOAD_ORDER_FACT" DESCRIPTION="Fact load with SQL override, nested lookups, router, and aggregator" ISVALID="YES" VERSIONNUMBER="1">
