        <INSTANCE NAME="TGT_AUDIT_RECON" TYPE="TARGET" TRANSFORMATION_NAME="TGT_AUDIT_RECON"/>
      </MAPPING>

      <MAPPING NAME="m_LOAD_DAILY_SALES_SUMMARY" DESCRIPTION="Daily aggregation mapping" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="SQ_TGT_ORDER_FACT" TYPE="Source Qualifier" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT ORDER_DATE, PRODUCT_KEY, NET_AMOUNT FROM TGT_ORDER_FACT WHERE ORDER_DATE = TO_DATE($$RUN_DATE,'YYYY-MM-DD')"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="lkp_PRODUCT_CATEGORY" TYPE="Lookup Procedure" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Lookup condition" VALUE="PRODUCT_KEY = IN_PRODUCT_KEY"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="agg_DAILY_CATEGORY" TYPE="Aggregator" REUSABLE="NO">
          <TRANSFORMFIELD NAME="ORDER_DATE" DATATYPE="date/time" PRECISION="19" SCALE="0" PORTTYPE="INPUT/OUTPUT" GROUP="YES"/>
          <TRANSFORMFIELD NAME="CATEGORY_DESC" DATATYPE="string" PRECISION="80" SCALE="0" PORTTYPE="INPUT/OUTPUT" GROUP="YES"/>
          <TRANSFORMFIELD NAME="ORDER_COUNT" DATATYPE="decimal" PRECISION="10" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION="COUNT(*)"/>
          <TRANSFORMFIELD NAME="TOTAL_AMOUNT" DATATYPE="decimal" PRECISION="18" SCALE="2" PORTTYPE="OUTPUT" EXPRESSION="SUM(NET_AMOUNT)"/>
        </TRANSFORMATION>
        <INSTANCE NAME="TGT_DAILY_SALES_SUMMARY" TYPE="TARGET" TRANSFORMATION_NAME="TGT_DAILY_SALES_SUMMARY"/>
      </MAPPING>

      <MAPPING NAME="m_LOAD_STATUS_REFERENCE" DESCRIPTION="Simple reference mapping" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="SQ_SRC_STATUS_REF" TYPE="Source Qualifier" REUSABLE="NO"/>
        <TRANSFORMATION NAME="exp_STATUS_DEFAULTS" TYPE="Expression" REUSABLE="NO">
          <TRANSFORMFIELD NAME="STATUS_DESC_OUT" DATATYPE="string" PRECISION="80" SCALE="0" PORTTYPE="OUTPUT" EXPRESSION="IIF(ISNULL(STATUS_DESC),'Unknown',STATUS_DESC)"/>
        </TRANSFORMATION>
        <INSTANCE NAME="SRC_STATUS_REF" TYPE="SOURCE" TRANSFORMATION_NAME="SRC_STATUS_REF"/>
        <INSTANCE NAME="TGT_STATUS_REFERENCE" TYPE="TARGET" TRANSFORMATION_NAME="TGT_STATUS_REFERENCE"/>
      </MAPPING>

      <WORKFLOW NAME="wf_DAILY_WAREHOUSE_LOAD" DESCRIPTION="Workflow and sessions for all synthetic mappings" SERVERNAME="IS_LOCAL" SCHEDULERNAME="Daily">
        <TASK NAME="Start" TYPE="Start"/>
        <SESSION NAME="s_LOAD_STATUS_REFERENCE" MAPPINGNAME="m_LOAD_STATUS_REFERENCE" REUSABLE="NO">
          <ATTRIBUTE NAME="Commit Interval" VALUE="10000"/>
          <ATTRIBUTE NAME="Treat Source Rows As" VALUE="Insert"/>
        </SESSION>
        <SESSION NAME="s_LOAD_PRODUCT_DIM_WITH_MAPPLET" MAPPINGNAME="m_LOAD_PRODUCT_DIM_WITH_MAPPLET" REUSABLE="NO">
          <ATTRIBUTE NAME="Parameter File Name" VALUE="$PMRootDir/param/dbt_fixture.parm"/>
        </SESSION>
        <SESSION NAME="s_LOAD_CUSTOMER_DIM" MAPPINGNAME="m_LOAD_CUSTOMER_DIM" REUSABLE="NO">
          <ATTRIBUTE NAME="Parameter File Name" VALUE="$PMRootDir/param/dbt_fixture.parm"/>
          <ATTRIBUTE NAME="Recovery Strategy" VALUE="Resume from last checkpoint"/>
        </SESSION>
        <SESSION NAME="s_LOAD_ORDER_FACT" MAPPINGNAME="m_LOAD_ORDER_FACT" REUSABLE="NO">
          <ATTRIBUTE NAME="Treat Source Rows As" VALUE="Data Driven"/>
        </SESSION>
        <SESSION NAME="s_LOAD_DAILY_SALES_SUMMARY" MAPPINGNAME="m_LOAD_DAILY_SALES_SUMMARY" REUSABLE="NO"/>
        <SESSION NAME="s_AUDIT_RECON_WORKFLOW_EDGE" MAPPINGNAME="m_AUDIT_RECON_WORKFLOW_EDGE" REUSABLE="NO"/>
        <TASK NAME="cmd_NOTIFY_DONE" TYPE="Command">
          <ATTRIBUTE NAME="Command" VALUE="echo warehouse load complete for $$RUN_DATE"/>
        </TASK>
        <WORKFLOWLINK FROMTASK="Start" TOTASK="s_LOAD_STATUS_REFERENCE" CONDITION=""/>
        <WORKFLOWLINK FROMTASK="s_LOAD_STATUS_REFERENCE" TOTASK="s_LOAD_PRODUCT_DIM_WITH_MAPPLET" CONDITION="$s_LOAD_STATUS_REFERENCE.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_LOAD_PRODUCT_DIM_WITH_MAPPLET" TOTASK="s_LOAD_CUSTOMER_DIM" CONDITION="$s_LOAD_PRODUCT_DIM_WITH_MAPPLET.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_LOAD_CUSTOMER_DIM" TOTASK="s_LOAD_ORDER_FACT" CONDITION="$s_LOAD_CUSTOMER_DIM.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_LOAD_ORDER_FACT" TOTASK="s_LOAD_DAILY_SALES_SUMMARY" CONDITION="$s_LOAD_ORDER_FACT.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_LOAD_DAILY_SALES_SUMMARY" TOTASK="s_AUDIT_RECON_WORKFLOW_EDGE" CONDITION="$s_LOAD_DAILY_SALES_SUMMARY.Status = SUCCEEDED"/>
        <WORKFLOWLINK FROMTASK="s_AUDIT_RECON_WORKFLOW_EDGE" TOTASK="cmd_NOTIFY_DONE" CONDITION="$s_AUDIT_RECON_WORKFLOW_EDGE.Status = SUCCEEDED"/>
      </WORKFLOW>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
