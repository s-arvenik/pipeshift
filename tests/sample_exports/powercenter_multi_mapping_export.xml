      <MAPPING NAME="m_LOAD_CUSTOMER_DIM" DESCRIPTION="Complex customer dimension mapping with chained expressions and lookups" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="SQ_SRC_CUSTOMER_RAW" TYPE="Source Qualifier" REUSABLE="NO">
          <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT CUSTOMER_ID, CUSTOMER_NAME, EMAIL_ADDRESS, STATUS_CODE, UPDATED_AT FROM SRC_CUSTOMER_RAW WHERE UPDATED_AT &gt;= $$LAST_RUN_TS"/>
          <TRANSFORMFIELD NAME="CUSTOMER_ID" DATATYPE="decimal" PRECISION="10" SCALE="0" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CUSTOMER_NAME" DATATYPE="string" PRECISION="100" SCALE="0" PORTTYPE="OUTPUT"/>
